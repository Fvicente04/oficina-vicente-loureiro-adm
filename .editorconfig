# EditorConfig helps maintain consistent coding styles
# for multiple developers working on the same project across
# various editors and IDEs.

root = true

# All files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# TypeScript/JavaScript files
[*.{ts,tsx,js,jsx,json}]
indent_size = 2

# SCSS/CSS files
[*.{scss,css,sass}]
indent_size = 2

# HTML files
[*.html]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_size = 2
