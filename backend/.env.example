# ============================================================
# OFICINA VICENTE LOUREIRO - BACKEND ENVIRONMENT VARIABLES
# Copie este arquivo para .env e configure conforme necessário
# ============================================================

# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV=development
PORT=3001

# ============================================================
# DATABASE
# ============================================================
# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=oficina_user
DB_PASSWORD=sua_senha_segura_aqui
DB_NAME=oficina_gestao
DB_DIALECT=postgres

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET=sua_chave_secreta_super_segura_aqui_minimo_32_caracteres
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=sua_chave_refresh_super_segura_aqui_minimo_32_caracteres
JWT_REFRESH_EXPIRATION=7d

# ============================================================
# API
# ============================================================
API_URL=http://localhost:3001
API_PREFIX=/api

# ============================================================
# CORS
# ============================================================
CORS_ORIGIN=http://localhost:4200

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================================
# SESSION
# ============================================================
SESSION_SECRET=sua_session_secret_aqui

# ============================================================
# EMAIL (SMTP) - Opcional
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app_aqui
SMTP_FROM=noreply@oficinavicenteloureiro.com.br

# ============================================================
# UPLOADS
# ============================================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10mb

# ============================================================
# FRONTEND
# ============================================================
FRONTEND_URL=http://localhost:4200

# ============================================================
# TIMEZONE
# ============================================================
TZ=America/Sao_Paulo

# ============================================================
# DEBUG
# ============================================================
DEBUG=false
